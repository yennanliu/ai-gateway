# Copy to .env in this directory to override compose defaults.

# Default: SQLite on the shared volume. For the `scale` profile (Postgres):
#   AIGW_DATABASE_URL=postgresql+psycopg://aigw:aigw@postgres:5432/aigw
#   AIGW_REDIS_URL=redis://redis:6379/0
AIGW_DATABASE_URL=sqlite:////data/ai-gateway.db
AIGW_REDIS_URL=
