# AI Gateway — local dev config. Copy to `.env`; every value has a safe default.

# Datastore: SQLite file by default. For Postgres:
#   AIGW_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/aigw
AIGW_DATABASE_URL=sqlite:///./ai-gateway.db

# Cache: empty => in-process fallback (no Redis needed locally).
#   AIGW_REDIS_URL=redis://localhost:6379/0
AIGW_REDIS_URL=

# Secrets provider: "env" (local) or "vault" (prod).
AIGW_SECRETS_PROVIDER=env

AIGW_ENVIRONMENT=local
